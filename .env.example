# Copy this file to .env.local and fill in your values

# Backend API base URL
# For local XAMPP: http://localhost/reactJS/FixBhai/backend/api
# For production: https://api.fixbhai.in/v1
VITE_API_URL=http://localhost/reactJS/FixBhai/backend/api

# Request timeout in milliseconds
VITE_API_TIMEOUT=10000

# Set to 'false' to use real API calls (requires backend)
# Set to 'true' for mock mode (offline development)
VITE_USE_MOCK=false
