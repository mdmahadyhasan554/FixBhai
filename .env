# FixBhai environment variables
# Copy to .env.local and override for your environment

# Backend API base URL (local XAMPP)
# Path format: http://localhost/[htdocs-subfolder]/backend/api
VITE_API_URL=http://localhost/reactJS/FixBhai/backend/api

# Request timeout in milliseconds
VITE_API_TIMEOUT=10000

# Set to 'false' to use real API calls (requires backend)
VITE_USE_MOCK=false
